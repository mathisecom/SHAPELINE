{% comment %}
  Section Shopify : Avis clients + questions façon Judge.me/Loox
  Installation : Online Store > Themes > Edit code > Sections > Add a new section
  Nom conseillé : avis-clients-pagination.liquid
{% endcomment %}

<section id="AvisClients-{{ section.id }}" class="avis-clients-section">
  <div class="avis-wrap">
    <div class="avis-summary-card">
      <h2>{{ section.settings.heading }}</h2>

      <div class="avis-summary-grid">
        <div class="avis-score-block">
          <div class="avis-stars" aria-label="Note moyenne {{ section.settings.average_rating }} sur 5">★★★★★</div>
          <div class="avis-average"><strong>{{ section.settings.average_rating }}</strong> sur 5</div>
          <div class="avis-count">Basé sur {{ section.settings.total_reviews }} avis <span class="avis-check">✓</span></div>
        </div>

        <div class="avis-bars-block" aria-label="Répartition des notes">
          {% assign total_float = section.settings.total_reviews | plus: 0.0 %}
          {% assign five_pct = section.settings.five_star_count | times: 100 | divided_by: total_float %}
          {% assign four_pct = section.settings.four_star_count | times: 100 | divided_by: total_float %}
          {% assign three_pct = section.settings.three_star_count | times: 100 | divided_by: total_float %}
          {% assign two_pct = section.settings.two_star_count | times: 100 | divided_by: total_float %}
          {% assign one_pct = section.settings.one_star_count | times: 100 | divided_by: total_float %}

          <div class="avis-bar-row"><span>★★★★★</span><div><i style="width: {{ five_pct }}%"></i></div><em>{{ section.settings.five_star_count }}</em></div>
          <div class="avis-bar-row"><span>★★★★☆</span><div><i style="width: {{ four_pct }}%"></i></div><em>{{ section.settings.four_star_count }}</em></div>
          <div class="avis-bar-row"><span>★★★☆☆</span><div><i style="width: {{ three_pct }}%"></i></div><em>{{ section.settings.three_star_count }}</em></div>
          <div class="avis-bar-row"><span>★★☆☆☆</span><div><i style="width: {{ two_pct }}%"></i></div><em>{{ section.settings.two_star_count }}</em></div>
          <div class="avis-bar-row"><span>★☆☆☆☆</span><div><i style="width: {{ one_pct }}%"></i></div><em>{{ section.settings.one_star_count }}</em></div>
        </div>

        <div class="avis-actions-block">
          <a class="avis-btn avis-btn-primary" href="{{ section.settings.write_review_link }}">{{ section.settings.write_review_label }}</a>
          <a class="avis-btn avis-btn-outline" href="{{ section.settings.ask_question_link }}">{{ section.settings.ask_question_label }}</a>
        </div>
      </div>

      <div class="avis-gallery-line"></div>

      <div class="avis-gallery-wrap">
        <p>{{ section.settings.gallery_label }}</p>
        <div class="avis-gallery">
          {% assign gallery_count = 0 %}
          {% for block in section.blocks %}
            {% if block.type == 'review' and block.settings.photo != blank and gallery_count < 8 %}
              <button class="avis-thumb" type="button" data-review-jump="{{ block.settings.page }}" {{ block.shopify_attributes }}>
                {{ block.settings.photo | image_url: width: 160 | image_tag: loading: 'lazy', alt: block.settings.name }}
              </button>
              {% assign gallery_count = gallery_count | plus: 1 %}
            {% endif %}
          {% endfor %}
          <button class="avis-see-more" type="button" data-open-page="1">Voir<br>plus</button>
        </div>
      </div>
    </div>

    <div class="avis-tabs-card">
      <div class="avis-tabs">
        <button type="button" class="avis-tab active" data-tab="reviews">Avis ({{ section.settings.total_reviews }})</button>
        <button type="button" class="avis-tab" data-tab="questions">Questions ({{ section.settings.questions_count }})</button>
      </div>
      <div class="avis-filter-row">
        <button type="button" class="avis-filter" data-filter-pictures="false">Uniquement les photos <span>⌄</span></button>
      </div>
    </div>

    <div class="avis-panel avis-panel-reviews active" data-panel="reviews">
      <div class="avis-reviews-grid">
        {% for block in section.blocks %}
          {% if block.type == 'review' %}
            <article class="avis-card" data-page="{{ block.settings.page }}" data-has-image="{% if block.settings.photo != blank %}true{% else %}false{% endif %}" {{ block.shopify_attributes }}>
              <div class="avis-card-top">
                <div>
                  <div class="avis-card-stars">
                    {% for i in (1..5) %}{% if i <= block.settings.rating %}★{% else %}☆{% endif %}{% endfor %}
                  </div>
                  <div class="avis-author-row">
                    <span class="avis-avatar" aria-hidden="true">♙</span>
                    <strong>{{ block.settings.name }}</strong>
                    {% if block.settings.verified %}<span class="avis-verified">Vérifié</span>{% endif %}
                  </div>
                </div>
                <div class="avis-date-pin">
                  <span>{{ block.settings.date }}</span>
                  <span class="avis-pin">⌁</span>
                </div>
              </div>

              {% if block.settings.photo != blank %}
                <div class="avis-photo">
                  {{ block.settings.photo | image_url: width: 720 | image_tag: loading: 'lazy', alt: block.settings.name }}
                </div>
              {% else %}
                <div class="avis-photo avis-photo-placeholder">Ajoute la photo de cet avis dans l’éditeur Shopify</div>
              {% endif %}

              <p class="avis-text">{{ block.settings.text }}</p>
            </article>
          {% endif %}
        {% endfor %}
      </div>

      <nav class="avis-pagination" aria-label="Pagination des avis"></nav>
    </div>

    <div class="avis-panel avis-panel-questions" data-panel="questions">
      <div class="avis-questions-list">
        <article class="avis-question-card" data-question-page="1">
          <div class="avis-question-head">
            <div class="avis-question-author"><span class="avis-question-avatar" aria-hidden="true">♙</span><strong>John Williams</strong></div>
            <span>01/09/2024</span>
          </div>
          <p class="avis-question-text">Je porte des t-shirts 3XL et des pantalons taille 44. Est-ce que le débardeur 2XL devrait m’aller ?</p>
          <div class="avis-answer-box"><span>01/10/2024</span><strong>&gt;&gt; {{ section.settings.shop_name }} a répondu :</strong><p>Bien sûr ! Nos débardeurs {{ section.settings.shop_name }} taillent différemment d’un t-shirt classique, donc le 2XL devrait t’aller même si tu portes habituellement du 3XL. Pour plus de précision, utilise notre guide des tailles IA sur le site afin de trouver ta taille idéale.</p></div>
        </article>

        <article class="avis-question-card" data-question-page="1">
          <div class="avis-question-head">
            <div class="avis-question-author"><span class="avis-question-avatar" aria-hidden="true">♙</span><strong>Richard Garcia</strong></div>
            <span>01/08/2024</span>
          </div>
          <p class="avis-question-text">J’en ai acheté 3 : les 2 tailles L me vont bien, mais le XL ne me va pas. Est-ce que je peux l’échanger contre un autre L ?</p>
          <div class="avis-answer-box"><span>01/09/2024</span><strong>&gt;&gt; {{ section.settings.shop_name }} a répondu :</strong><p>Bien sûr ! Contacte-nous par e-mail ou via le formulaire de contact et nous t’aiderons à remplacer le XL par une taille L. On est là pour trouver la bonne solution pour toi.</p></div>
        </article>

        <article class="avis-question-card" data-question-page="1">
          <div class="avis-question-head">
            <div class="avis-question-author"><span class="avis-question-avatar" aria-hidden="true">♙</span><strong>Robert</strong></div>
            <span>01/08/2024</span>
          </div>
          <p class="avis-question-text">Est-ce que le débardeur est assez long ? Mes sous-vêtements remontent souvent et je veux éviter ce problème.</p>
          <div class="avis-answer-box"><span>01/09/2024</span><strong>&gt;&gt; {{ section.settings.shop_name }} a répondu :</strong><p>Oui, notre modèle est conçu pour être plus long et mieux rester en place. Il tient bien rentré sous les vêtements pour un maintien plus sûr tout au long de la journée.</p></div>
        </article>

        <article class="avis-question-card" data-question-page="1">
          <div class="avis-question-head">
            <div class="avis-question-author"><span class="avis-question-avatar" aria-hidden="true">♙</span><strong>Jacob</strong></div>
            <span>01/07/2024</span>
          </div>
          <p class="avis-question-text">Est-ce que la matière est confortable à porter pendant plus de 8 heures dans la journée ?</p>
          <div class="avis-answer-box"><span>01/08/2024</span><strong>&gt;&gt; {{ section.settings.shop_name }} a répondu :</strong><p>Oui, le tissu est pensé pour rester agréable toute la journée. Beaucoup de clients le portent pendant de longues heures sans gêne particulière.</p></div>
        </article>

        <article class="avis-question-card" data-question-page="1">
          <div class="avis-question-head">
            <div class="avis-question-author"><span class="avis-question-avatar" aria-hidden="true">♙</span><strong>David Lopez</strong></div>
            <span>01/07/2024</span>
          </div>
          <p class="avis-question-text">Est-ce qu’il a tendance à remonter souvent ?</p>
          <div class="avis-answer-box"><span>01/08/2024</span><strong>&gt;&gt; {{ section.settings.shop_name }} a répondu :</strong><p>Non, il est conçu pour rester bien en place. Tu ne devrais donc pas avoir de souci de débardeur qui remonte pendant la journée.</p></div>
        </article>

        <article class="avis-question-card" data-question-page="2">
          <div class="avis-question-head">
            <div class="avis-question-author"><span class="avis-question-avatar" aria-hidden="true">♙</span><strong>Doni</strong></div>
            <span>01/07/2024</span>
          </div>
          <p class="avis-question-text">Quelle taille devrais-je prendre ? Je mesure 1m75 pour environ 132 kg.</p>
          <div class="avis-answer-box"><span>01/08/2024</span><strong>&gt;&gt; {{ section.settings.shop_name }} a répondu :</strong><p>Pour ta taille et ton poids, le 2XL serait probablement le meilleur choix. Tu peux aussi utiliser notre guide des tailles IA sur le site pour confirmer la taille idéale.</p></div>
        </article>

        <article class="avis-question-card" data-question-page="2">
          <div class="avis-question-head">
            <div class="avis-question-author"><span class="avis-question-avatar" aria-hidden="true">♙</span><strong>James R.</strong></div>
            <span>01/05/2024</span>
          </div>
          <p class="avis-question-text">Est-ce que ça aide pour les poignées d’amour et la poitrine masculine ?</p>
          <div class="avis-answer-box"><span>01/06/2024</span><strong>&gt;&gt; {{ section.settings.shop_name }} a répondu :</strong><p>Oui, le débardeur {{ section.settings.shop_name }} aide à lisser les zones comme le ventre, les poignées d’amour et le torse grâce à son tissu gainant et à sa coupe près du corps.</p></div>
        </article>

        <article class="avis-question-card" data-question-page="2">
          <div class="avis-question-head">
            <div class="avis-question-author"><span class="avis-question-avatar" aria-hidden="true">♙</span><strong>Thomas</strong></div>
            <span>01/04/2024</span>
          </div>
          <p class="avis-question-text">Je mesure 1m80 pour environ 91 kg. Quelle taille me conviendrait ?</p>
          <div class="avis-answer-box"><span>01/05/2024</span><strong>&gt;&gt; {{ section.settings.shop_name }} a répondu :</strong><p>Pour ta taille et ton poids, une taille L devrait être idéale si tu veux un effet bien ajusté. Le guide des tailles IA peut aussi t’aider à confirmer.</p></div>
        </article>

        <article class="avis-question-card" data-question-page="2">
          <div class="avis-question-head">
            <div class="avis-question-author"><span class="avis-question-avatar" aria-hidden="true">♙</span><strong>Mark</strong></div>
            <span>01/03/2024</span>
          </div>
          <p class="avis-question-text">Comment est-ce que ça rend sous un polo ?</p>
          <div class="avis-answer-box"><span>01/04/2024</span><strong>&gt;&gt; {{ section.settings.shop_name }} a répondu :</strong><p>Le débardeur est conçu pour rester discret sous différents types de hauts, y compris les polos, afin d’obtenir une silhouette plus lisse sans lignes trop visibles.</p></div>
        </article>

        <article class="avis-question-card" data-question-page="2">
          <div class="avis-question-head">
            <div class="avis-question-author"><span class="avis-question-avatar" aria-hidden="true">♙</span><strong>Matthew</strong></div>
            <span>01/02/2024</span>
          </div>
          <p class="avis-question-text">Je mesure 1m65 pour environ 111 kg. Quelle taille serait la meilleure pour moi ?</p>
          <div class="avis-answer-box"><span>01/03/2024</span><strong>&gt;&gt; {{ section.settings.shop_name }} a répondu :</strong><p>Le 2XL devrait être confortable pour toi. Si tu préfères un effet plus serré, tu peux envisager le XL, mais le guide des tailles reste le plus précis.</p></div>
        </article>

        <article class="avis-question-card" data-question-page="3">
          <div class="avis-question-head">
            <div class="avis-question-author"><span class="avis-question-avatar" aria-hidden="true">♙</span><strong>Michael</strong></div>
            <span>01/01/2024</span>
          </div>
          <p class="avis-question-text">Je mesure 1m80 et je pèse environ 99 kg. Avant je pesais 165 kg et j’ai maintenant de la peau relâchée. Quelle taille me faut-il ?</p>
          <div class="avis-answer-box"><span>01/02/2024</span><strong>&gt;&gt; {{ section.settings.shop_name }} a répondu :</strong><p>Bravo pour ta perte de poids ! Pour ton gabarit, une taille XL devrait être un très bon choix. Utilise notre guide des tailles IA pour confirmer selon le niveau de maintien souhaité.</p></div>
        </article>

        <article class="avis-question-card" data-question-page="3">
          <div class="avis-question-head">
            <div class="avis-question-author"><span class="avis-question-avatar" aria-hidden="true">♙</span><strong>Eric</strong></div>
            <span>01/01/2024</span>
          </div>
          <p class="avis-question-text">Est-ce que le tissu garde une mauvaise odeur après une longue journée ?</p>
          <div class="avis-answer-box"><span>01/02/2024</span><strong>&gt;&gt; {{ section.settings.shop_name }} a répondu :</strong><p>Non, le tissu est pensé pour rester frais même après plusieurs heures de port. Jusqu’ici, nos clients ne nous remontent pas ce type de problème.</p></div>
        </article>

        <article class="avis-question-card" data-question-page="3">
          <div class="avis-question-head">
            <div class="avis-question-author"><span class="avis-question-avatar" aria-hidden="true">♙</span><strong>Andrew</strong></div>
            <span>01/01/2024</span>
          </div>
          <p class="avis-question-text">Je mesure 1m78 et je pèse environ 73 kg. Quelle taille devrais-je prendre ?</p>
          <div class="avis-answer-box"><span>01/02/2024</span><strong>&gt;&gt; {{ section.settings.shop_name }} a répondu :</strong><p>Pour 1m78 et 73 kg, une taille S devrait offrir le meilleur rendu avec notre débardeur {{ section.settings.shop_name }}.</p></div>
        </article>

        <article class="avis-question-card" data-question-page="3">
          <div class="avis-question-head">
            <div class="avis-question-author"><span class="avis-question-avatar" aria-hidden="true">♙</span><strong>Charles Davis</strong></div>
            <span>29/12/2023</span>
          </div>
          <p class="avis-question-text">Est-ce que je peux le porter dehors par une journée chaude et ensoleillée, ou je risque d’avoir trop chaud ?</p>
          <div class="avis-answer-box"><span>29/12/2023</span><strong>&gt;&gt; {{ section.settings.shop_name }} a répondu :</strong><p>Aucun souci. Beaucoup de clients le portent même quand il fait chaud et trouvent le débardeur confortable, respirant et agréable au quotidien.</p></div>
        </article>

        <article class="avis-question-card" data-question-page="3">
          <div class="avis-question-head">
            <div class="avis-question-author"><span class="avis-question-avatar" aria-hidden="true">♙</span><strong>Joseph</strong></div>
            <span>29/12/2023</span>
          </div>
          <p class="avis-question-text">Est-ce que ça aide à perdre du poids ou à réduire le ventre ?</p>
          <div class="avis-answer-box"><span>30/12/2023</span><strong>&gt;&gt; {{ section.settings.shop_name }} a répondu :</strong><p>Le débardeur aide surtout à lisser la silhouette et à améliorer le maintien. Certains clients se sentent plus motivés pendant le sport, mais l’alimentation et l’activité physique restent essentielles pour la perte de poids.</p></div>
        </article>
      </div>

      <nav class="avis-question-pagination" aria-label="Pagination des questions"></nav>
    </div>
  </div>
</section>

<style>
  #AvisClients-{{ section.id }} {
    --avis-text: #111;
    --avis-muted: #646464;
    --avis-border: #111;
    --avis-soft-border: #e9e9e9;
    --avis-bg: #fff;
    --avis-shadow: 0 6px 18px rgba(0,0,0,.08);
    color: var(--avis-text);
    font-family: inherit;
    padding: {{ section.settings.section_padding_top }}px 0 {{ section.settings.section_padding_bottom }}px;
  }

  #AvisClients-{{ section.id }} * { box-sizing: border-box; }

  #AvisClients-{{ section.id }} .avis-wrap {
    width: min({{ section.settings.max_width }}px, calc(100% - 32px));
    margin: 0 auto;
  }

  #AvisClients-{{ section.id }} .avis-summary-card,
  #AvisClients-{{ section.id }} .avis-tabs-card,
  #AvisClients-{{ section.id }} .avis-card,
  #AvisClients-{{ section.id }} .avis-empty {
    background: var(--avis-bg);
    border-radius: 8px;
    box-shadow: var(--avis-shadow);
  }

  #AvisClients-{{ section.id }} .avis-summary-card {
    padding: 26px 34px 30px;
    margin-bottom: 22px;
  }

  #AvisClients-{{ section.id }} h2 {
    margin: 0 0 22px;
    text-align: center;
    font-size: clamp(20px, 2vw, 26px);
    line-height: 1.15;
    font-weight: 800;
  }

  #AvisClients-{{ section.id }} .avis-summary-grid {
    display: grid;
    grid-template-columns: 1fr 1.35fr 1fr;
    align-items: center;
    gap: 34px;
  }

  #AvisClients-{{ section.id }} .avis-score-block,
  #AvisClients-{{ section.id }} .avis-bars-block,
  #AvisClients-{{ section.id }} .avis-actions-block {
    min-height: 96px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  #AvisClients-{{ section.id }} .avis-score-block,
  #AvisClients-{{ section.id }} .avis-actions-block { text-align: center; }

  #AvisClients-{{ section.id }} .avis-bars-block,
  #AvisClients-{{ section.id }} .avis-actions-block { border-left: 2px solid var(--avis-border); padding-left: 34px; }

  #AvisClients-{{ section.id }} .avis-stars,
  #AvisClients-{{ section.id }} .avis-card-stars {
    letter-spacing: 2px;
    font-size: 16px;
    line-height: 1;
    color: #000;
  }

  #AvisClients-{{ section.id }} .avis-average,
  #AvisClients-{{ section.id }} .avis-count {
    font-size: 13px;
    color: var(--avis-muted);
    margin-top: 4px;
  }

  #AvisClients-{{ section.id }} .avis-check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 14px;
    height: 14px;
    border-radius: 2px;
    background: #54c6b0;
    color: #fff;
    font-size: 10px;
    vertical-align: middle;
  }

  #AvisClients-{{ section.id }} .avis-bar-row {
    display: grid;
    grid-template-columns: 76px 1fr 34px;
    gap: 12px;
    align-items: center;
    font-size: 12px;
    margin: 6px 0;
  }

  #AvisClients-{{ section.id }} .avis-bar-row span { letter-spacing: 1px; }
  #AvisClients-{{ section.id }} .avis-bar-row div { height: 10px; background: #ededed; border-radius: 999px; overflow: hidden; }
  #AvisClients-{{ section.id }} .avis-bar-row i { display: block; height: 100%; background: #000; border-radius: inherit; }
  #AvisClients-{{ section.id }} .avis-bar-row em { font-style: normal; color: var(--avis-muted); text-align: left; }

  #AvisClients-{{ section.id }} .avis-btn {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    width: min(230px, 100%);
    min-height: 38px;
    margin: 5px auto;
    border: 2px solid #000;
    border-radius: 999px;
    font-weight: 800;
    font-size: 13px;
    text-decoration: none;
    transition: transform .2s ease, opacity .2s ease;
  }

  #AvisClients-{{ section.id }} .avis-btn:hover { transform: translateY(-1px); opacity: .88; }
  #AvisClients-{{ section.id }} .avis-btn-primary { background: #000; color: #fff; }
  #AvisClients-{{ section.id }} .avis-btn-outline { background: #fff; color: #000; }

  #AvisClients-{{ section.id }} .avis-gallery-line { border-top: 2px solid var(--avis-border); margin: 24px 0 20px; }
  #AvisClients-{{ section.id }} .avis-gallery-wrap { text-align: center; }
  #AvisClients-{{ section.id }} .avis-gallery-wrap p { margin: 0 0 9px; color: var(--avis-muted); font-size: 13px; }
  #AvisClients-{{ section.id }} .avis-gallery { display: inline-flex; align-items: center; gap: 8px; max-width: 100%; overflow-x: auto; padding-bottom: 2px; }
  #AvisClients-{{ section.id }} .avis-thumb { border: 0; padding: 0; background: transparent; cursor: pointer; flex: 0 0 auto; }
  #AvisClients-{{ section.id }} .avis-thumb img { width: 54px; height: 54px; object-fit: cover; border-radius: 4px; display: block; }
  #AvisClients-{{ section.id }} .avis-see-more { border: 0; background: transparent; text-decoration: underline; color: var(--avis-muted); font-size: 12px; line-height: 1.05; cursor: pointer; }

  #AvisClients-{{ section.id }} .avis-tabs-card { padding: 14px 18px 16px; margin-bottom: 28px; }
  #AvisClients-{{ section.id }} .avis-tabs { display: flex; gap: 12px; border-bottom: 2px solid #000; }
  #AvisClients-{{ section.id }} .avis-tab { border: 0; background: transparent; padding: 10px 14px; border-radius: 20px 20px 0 0; cursor: pointer; font-size: 13px; color: #111; }
  #AvisClients-{{ section.id }} .avis-tab.active { background: #f2f2f2; }
  #AvisClients-{{ section.id }} .avis-filter-row { margin-top: 13px; }
  #AvisClients-{{ section.id }} .avis-filter { border: 0; background: transparent; cursor: pointer; color: #111; font-size: 12px; padding: 0; }

  #AvisClients-{{ section.id }} .avis-panel { display: none; }
  #AvisClients-{{ section.id }} .avis-panel.active { display: block; }

  #AvisClients-{{ section.id }} .avis-reviews-grid {
    column-count: 3;
    column-gap: 24px;
  }

  #AvisClients-{{ section.id }} .avis-card {
    display: inline-block;
    width: 100%;
    margin: 0 0 24px;
    overflow: hidden;
    break-inside: avoid;
    vertical-align: top;
  }

  #AvisClients-{{ section.id }} .avis-card[hidden] { display: none !important; }
  #AvisClients-{{ section.id }} .avis-card-top { display: flex; justify-content: space-between; gap: 10px; padding: 16px 16px 12px; }
  #AvisClients-{{ section.id }} .avis-author-row { display: flex; align-items: center; gap: 7px; margin-top: 8px; font-size: 13px; }
