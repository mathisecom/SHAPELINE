    #AvisClients-{{ section.id }} .avis-reviews-grid { column-count: 1; }
    #AvisClients-{{ section.id }} .avis-tabs { overflow-x: auto; }
    #AvisClients-{{ section.id }} .avis-bar-row { grid-template-columns: 72px 1fr 30px; gap: 8px; }
  }
</style>

<script>
  (() => {
    const root = document.getElementById('AvisClients-{{ section.id }}');
    if (!root) return;

    const reviewCards = [...root.querySelectorAll('.avis-card')];
    const reviewPagination = root.querySelector('.avis-pagination');
    const questionCards = [...root.querySelectorAll('.avis-question-card')];
    const questionPagination = root.querySelector('.avis-question-pagination');
    const filterRow = root.querySelector('.avis-filter-row');

    const reviewTotalPages = Number('{{ section.settings.total_pages }}') || 7;
    const questionTotalPages = Math.max(1, ...questionCards.map(card => Number(card.dataset.questionPage) || 1));
    let currentReviewPage = 1;
    let currentQuestionPage = 1;
    let picturesOnly = false;

    const renderPager = (container, totalPages, currentPage, onPageChange) => {
      if (!container) return;
      container.innerHTML = '';

      const makeBtn = (label, page, className = '') => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = `avis-page-btn ${className}`;
        btn.textContent = label;
        btn.disabled = page < 1 || page > totalPages;
        btn.addEventListener('click', () => onPageChange(page, true));
        container.appendChild(btn);
      };

      makeBtn('«', 1);
      makeBtn('‹', currentPage - 1);
      for (let i = 1; i <= totalPages; i++) makeBtn(String(i), i, i === currentPage ? 'active' : '');
      makeBtn('›', currentPage + 1);
      makeBtn('»', totalPages);
    };

    const showReviewPage = (page, scroll = false) => {
      currentReviewPage = Math.max(1, Math.min(reviewTotalPages, Number(page) || 1));
      reviewCards.forEach(card => {
        const matchPage = Number(card.dataset.page) === currentReviewPage;
        const matchPhoto = !picturesOnly || card.dataset.hasImage === 'true';
        card.hidden = !(matchPage && matchPhoto);
      });
      renderPager(reviewPagination, reviewTotalPages, currentReviewPage, showReviewPage);
      if (scroll) root.querySelector('.avis-tabs-card')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    };

    const showQuestionPage = (page, scroll = false) => {
      currentQuestionPage = Math.max(1, Math.min(questionTotalPages, Number(page) || 1));
      questionCards.forEach(card => {
        card.hidden = Number(card.dataset.questionPage) !== currentQuestionPage;
      });
      renderPager(questionPagination, questionTotalPages, currentQuestionPage, showQuestionPage);
      if (scroll) root.querySelector('.avis-tabs-card')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    };

    const activateTab = (tabName) => {
      root.querySelectorAll('.avis-tab').forEach(t => t.classList.toggle('active', t.dataset.tab === tabName));
      root.querySelectorAll('.avis-panel').forEach(p => p.classList.toggle('active', p.dataset.panel === tabName));
      if (filterRow) filterRow.hidden = tabName !== 'reviews';
      if (tabName === 'questions') showQuestionPage(currentQuestionPage, false);
      if (tabName === 'reviews') showReviewPage(currentReviewPage, false);
    };

    root.querySelectorAll('[data-review-jump], [data-open-page]').forEach(btn => {
      btn.addEventListener('click', () => {
        activateTab('reviews');
        showReviewPage(btn.dataset.reviewJump || btn.dataset.openPage || 1, true);
      });
    });

    root.querySelectorAll('.avis-tab').forEach(tab => {
      tab.addEventListener('click', () => activateTab(tab.dataset.tab));
    });

    root.querySelector('[data-filter-pictures]')?.addEventListener('click', event => {
      picturesOnly = !picturesOnly;
      event.currentTarget.dataset.filterPictures = String(picturesOnly);
      event.currentTarget.classList.toggle('active', picturesOnly);
      showReviewPage(currentReviewPage, false);
    });

    showReviewPage(1, false);
    showQuestionPage(1, false);
    activateTab('reviews');
  })();
</script>

